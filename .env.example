# Expo: variables must be prefixed with EXPO_PUBLIC_ to be available in the app bundle.
# Copy to .env and adjust if needed.

# Production (default for this project)
EXPO_PUBLIC_API_BASE_URL=https://parkingsoft.de

# Local Symfony example:
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Android emulator to host PC:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# Optional: override filtered bookings path
# EXPO_PUBLIC_API_BOOKINGS_FILTER_PATH=/api/external/bookings/filter

# Optional: Expo Metro tunnel (ngrok) — often fixes "Cannot read properties of undefined (reading 'body')"
# Create free token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
